{
  "manifest_version": 3,
  "name": "Tab Refresher",
  "version": "1.1.0",
  "description": "Click the icon to auto-refresh the current tab every 60 seconds. Click again to stop.",
  "minimum_chrome_version": "88",
  "permissions": ["alarms", "storage"],
  "background": { "service_worker": "service-worker.js" },
  "action": {
    "default_title": "Tab Refresher: OFF (click to start)",
    "default_icon": {
      "16": "icons/grey-16.png",
      "32": "icons/grey-32.png",
      "48": "icons/grey-48.png",
      "128": "icons/grey-128.png"
    }
  },
  "icons": {
    "16": "icons/grey-16.png",
    "48": "icons/grey-48.png",
    "128": "icons/grey-128.png"
  }
}
